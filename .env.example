PORT=3000
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/postgres?schema=public&sslmode=require"
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=15000
DATABASE_TRANSACTION_MAX_WAIT_MS=10000
DATABASE_TRANSACTION_TIMEOUT_MS=30000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
AUTH_EXPOSE_EMAIL_TOKENS=true
SUPER_ADMIN_NAME=Ashwa Logix Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
MAIL_ENABLED=false
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_REPLY_TO_EMAIL=support@example.com
FRONTEND_BASE_URL=http://localhost:5173
