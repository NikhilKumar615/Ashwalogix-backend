// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum UserStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum OrganizationRole {
  ORG_ADMIN
  DISPATCHER
  OPERATIONS
  WAREHOUSE
  DRIVER
}

enum PlatformRole {
  SUPER_ADMIN
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ClientStatus {
  ACTIVE
  PROSPECT
  INACTIVE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum DriverLicenseType {
  LMV
  HMV
}

enum EmploymentType {
  EMPLOYEE
  CONTRACT
  INDEPENDENT
  THIRD_PARTY
}

enum FuelType {
  DIESEL
  CNG
  ELECTRIC
  PETROL
  OTHER
}

enum IndependentDriverRegistrationStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

enum VehicleOwnerType {
  OWNED
  ATTACHED
  THIRD_PARTY
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

enum InventoryItemStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

enum ShipmentType {
  INBOUND
  OUTBOUND
  TRANSFER
  RETURN
}

enum ShipmentMode {
  BUSINESS
  INTERNAL
}

enum ShipmentStatus {
  DRAFT
  PLANNED
  ASSIGNED
  EN_ROUTE_PICKUP
  AT_PICKUP
  PICKED_UP
  IN_TRANSIT
  AT_DELIVERY
  DELIVERED
  COMPLETED
  FAILED
  CANCELLED
}

enum ShipmentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ShipmentAssignmentStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum StopType {
  PICKUP
  DELIVERY
  CHECKPOINT
  TRANSIT
}

enum StopStatus {
  PENDING
  ARRIVED
  COMPLETED
  SKIPPED
}

enum EventSource {
  SYSTEM
  ADMIN
  DRIVER
  WAREHOUSE
  API
}

enum TrackingSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DocumentStatus {
  UPLOADED
  ARCHIVED
  DELETED
}

enum DocumentEntityType {
  SHIPMENT
  DRIVER
  CLIENT
  VEHICLE
  POD
  ORGANIZATION
}

enum ProofType {
  PICKUP
  DELIVERY
}

model Organization {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String
  legalName            String?               @map("legal_name")
  email                String?
  phone                String?
  gstNumber            String?               @map("gst_number")
  panNumber            String?               @map("pan_number")
  cinNumber            String?               @map("cin_number")
  addressLine1         String?               @map("address_line_1")
  addressLine2         String?               @map("address_line_2")
  city                 String?
  state                String?
  postalCode           String?               @map("postal_code")
  country              String?               @default("India")
  status               OrganizationStatus    @default(PENDING_APPROVAL)
  ownerUserId          String?               @map("owner_user_id") @db.Uuid
  submittedByUserId    String?               @map("submitted_by_user_id") @db.Uuid
  approvedAt           DateTime?             @map("approved_at")
  approvedByUserId     String?               @map("approved_by_user_id") @db.Uuid
  rejectedAt           DateTime?             @map("rejected_at")
  rejectedReason       String?               @map("rejected_reason")
  users                OrganizationUser[]
  companyClients              CompanyClient[]
  companyClientLocations      CompanyClientLocation[]
  drivers              Driver[]
  vehicles             Vehicle[]
  warehouses           Warehouse[]
  inventoryItems       InventoryItem[]
  inventoryStocks      InventoryStock[]
  inventoryMovements   InventoryMovement[]
  shipments            Shipment[]
  shipmentItems        ShipmentItem[]
  shipmentStops        ShipmentStop[]
  shipmentAssignments  ShipmentAssignment[]
  shipmentStatusEvents ShipmentStatusEvent[]
  trackingSessions     TrackingSession[]
  trackingPoints       TrackingPoint[]
  documents            Document[]
  proofOfDeliveries    ProofOfDelivery[]
  independentDriverRegistrations IndependentDriverRegistration[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@map("organizations")
}

model User {
  id                  String             @id @default(uuid()) @db.Uuid
  fullName            String             @map("full_name")
  email               String             @unique
  phone               String?            @unique
  passwordHash        String?            @map("password_hash")
  platformRole        PlatformRole?      @map("platform_role")
  status              UserStatus         @default(PENDING_VERIFICATION)
  emailVerifiedAt     DateTime?          @map("email_verified_at")
  verificationToken   String?            @unique @map("verification_token")
  verificationTokenExpiresAt DateTime?   @map("verification_token_expires_at")
  resetPasswordToken  String?            @unique @map("reset_password_token")
  resetPasswordTokenExpiresAt DateTime?  @map("reset_password_token_expires_at")
  approvedAt          DateTime?          @map("approved_at")
  approvedByUserId    String?            @map("approved_by_user_id") @db.Uuid
  rejectedAt          DateTime?          @map("rejected_at")
  rejectedReason      String?            @map("rejected_reason")
  lastLoginAt         DateTime?          @map("last_login_at")
  organizationMembers OrganizationUser[]
  driverProfile       Driver?
  approvedIndependentDriverRegistrations IndependentDriverRegistration[] @relation("IndependentDriverApprovedByUser")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("users")
}

model OrganizationUser {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now()) @map("joined_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@map("organization_users")
}

model CompanyClient {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  companyClientCode  String           @map("company_client_code")
  name               String
  legalName          String?          @map("legal_name")
  industry           String?
  status             ClientStatus     @default(ACTIVE)
  pan                String?
  gstin              String?
  creditTerms        String?          @map("credit_terms")
  notes              String?
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations          CompanyClientLocation[]
  shipments          Shipment[]
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([organizationId, companyClientCode])
  @@index([organizationId])
  @@index([status])
  @@index([name])
  @@index([gstin])
  @@map("company_clients")
}

model CompanyClientLocation {
  id                     String      @id @default(uuid()) @db.Uuid
  organizationId         String      @map("organization_id") @db.Uuid
  companyClientId        String      @map("company_client_id") @db.Uuid
  locationType           String      @map("location_type")
  name                   String
  addressLine1           String      @map("address_line_1")
  addressLine2           String?     @map("address_line_2")
  city                   String?
  state                  String?
  postalCode             String?     @map("postal_code")
  country                String?     @default("India")
  gstin                  String?
  contactName            String?     @map("contact_name")
  contactPhone           String?     @map("contact_phone")
  isPrimary              Boolean     @default(false) @map("is_primary")
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyClient          CompanyClient      @relation(fields: [companyClientId], references: [id], onDelete: Cascade)
  sourceShipments        Shipment[]  @relation("ShipmentSourceLocation")
  destinationShipments   Shipment[]  @relation("ShipmentDestinationLocation")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([companyClientId])
  @@index([companyClientId, isPrimary])
  @@map("company_client_locations")
}

model Driver {
  id                    String               @id @default(uuid()) @db.Uuid
  organizationId        String               @map("organization_id") @db.Uuid
  userId                String?              @unique @map("user_id") @db.Uuid
  driverCode            String               @map("driver_code")
  fullName              String               @map("full_name")
  phone                 String
  email                 String?
  employmentType        EmploymentType       @map("employment_type")
  status                DriverStatus         @default(ACTIVE)
  licenseNumber         String?              @map("license_number")
  licenseExpiry         DateTime?            @map("license_expiry")
  homeBase              String?              @map("home_base")
  notes                 String?
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  currentShipments      Shipment[]           @relation("ShipmentCurrentDriver")
  assignments           ShipmentAssignment[]
  statusEvents          ShipmentStatusEvent[]
  trackingSessions      TrackingSession[]
  trackingPoints        TrackingPoint[]
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@unique([organizationId, driverCode])
  @@index([organizationId])
  @@index([status])
  @@index([phone])
  @@index([licenseExpiry])
  @@map("drivers")
}

model Vehicle {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  vehicleNumber    String               @map("vehicle_number")
  vehicleType      String               @map("vehicle_type")
  capacityWeight   Decimal?             @map("capacity_weight") @db.Decimal(12, 2)
  capacityVolume   Decimal?             @map("capacity_volume") @db.Decimal(12, 2)
  ownerType        VehicleOwnerType     @default(OWNED) @map("owner_type")
  status           VehicleStatus        @default(ACTIVE)
  notes            String?
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentShipments Shipment[]           @relation("ShipmentCurrentVehicle")
  assignments      ShipmentAssignment[]
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([organizationId, vehicleNumber])
  @@index([organizationId])
  @@index([status])
  @@index([vehicleNumber])
  @@map("vehicles")
}

model Warehouse {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  warehouseCode    String            @map("warehouse_code")
  name             String
  addressLine1     String?           @map("address_line_1")
  addressLine2     String?           @map("address_line_2")
  city             String?
  state            String?
  postalCode       String?           @map("postal_code")
  country          String?           @default("India")
  status           WarehouseStatus   @default(ACTIVE)
  notes            String?
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryStocks  InventoryStock[]
  inventoryMovements InventoryMovement[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@unique([organizationId, warehouseCode])
  @@index([organizationId])
  @@index([status])
  @@map("warehouses")
}

model InventoryItem {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  itemCode         String               @map("item_code")
  name             String
  description      String?
  category         String?
  unitOfMeasure    String               @map("unit_of_measure")
  minThreshold     Decimal?             @map("min_threshold") @db.Decimal(12, 2)
  maxThreshold     Decimal?             @map("max_threshold") @db.Decimal(12, 2)
  status           InventoryItemStatus  @default(ACTIVE)
  notes            String?
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryStocks  InventoryStock[]
  inventoryMovements InventoryMovement[]
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([organizationId, itemCode])
  @@index([organizationId])
  @@index([status])
  @@index([category])
  @@map("inventory_items")
}

model InventoryStock {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  warehouseId      String         @map("warehouse_id") @db.Uuid
  inventoryItemId  String         @map("inventory_item_id") @db.Uuid
  storageLocation  String?        @map("storage_location")
  quantityOnHand   Decimal        @default(0) @map("quantity_on_hand") @db.Decimal(12, 2)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([warehouseId, inventoryItemId, storageLocation])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([inventoryItemId])
  @@map("inventory_stocks")
}

model InventoryMovement {
  id               String                @id @default(uuid()) @db.Uuid
  organizationId   String                @map("organization_id") @db.Uuid
  warehouseId      String                @map("warehouse_id") @db.Uuid
  inventoryItemId  String                @map("inventory_item_id") @db.Uuid
  movementType     InventoryMovementType @map("movement_type")
  quantity         Decimal               @db.Decimal(12, 2)
  storageLocation  String?               @map("storage_location")
  referenceType    String?               @map("reference_type")
  referenceId      String?               @map("reference_id")
  notes            String?
  performedBy      String?               @map("performed_by") @db.Uuid
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse        Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([warehouseId])
  @@index([inventoryItemId])
  @@index([referenceId])
  @@index([createdAt(sort: Desc)])
  @@map("inventory_movements")
}

model Shipment {
  id                   String                @id @default(uuid()) @db.Uuid
  organizationId       String                @map("organization_id") @db.Uuid
  shipmentCode         String                @map("shipment_code")
  companyClientId      String?               @map("company_client_id") @db.Uuid
  shipmentMode         ShipmentMode          @default(BUSINESS) @map("shipment_mode")
  shipmentType         ShipmentType          @map("shipment_type")
  status               ShipmentStatus        @default(DRAFT)
  priority             ShipmentPriority      @default(MEDIUM)
  sourceLocationId     String?               @map("source_location_id") @db.Uuid
  destinationLocationId String?              @map("destination_location_id") @db.Uuid
  sourceAddressSnapshot Json?                @map("source_address_snapshot")
  destinationAddressSnapshot Json?           @map("destination_address_snapshot")
  plannedPickupAt      DateTime?             @map("planned_pickup_at")
  plannedDeliveryAt    DateTime?             @map("planned_delivery_at")
  actualPickupAt       DateTime?             @map("actual_pickup_at")
  actualDeliveryAt     DateTime?             @map("actual_delivery_at")
  currentDriverId      String?               @map("current_driver_id") @db.Uuid
  currentVehicleId     String?               @map("current_vehicle_id") @db.Uuid
  currentTrackingSessionId String?           @unique @map("current_tracking_session_id") @db.Uuid
  invoiceNumber        String?               @map("invoice_number")
  invoiceDate          DateTime?             @map("invoice_date")
  invoiceAmount        Decimal?              @map("invoice_amount") @db.Decimal(14, 2)
  internalSenderName   String?               @map("internal_sender_name")
  internalSenderPhone  String?               @map("internal_sender_phone")
  internalSenderDepartment String?           @map("internal_sender_department")
  internalReceiverName String?               @map("internal_receiver_name")
  internalReceiverPhone String?              @map("internal_receiver_phone")
  internalReceiverDepartment String?         @map("internal_receiver_department")
  notes                String?
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyClient        CompanyClient?        @relation(fields: [companyClientId], references: [id], onDelete: Restrict)
  sourceLocation       CompanyClientLocation?       @relation("ShipmentSourceLocation", fields: [sourceLocationId], references: [id], onDelete: SetNull)
  destinationLocation  CompanyClientLocation?       @relation("ShipmentDestinationLocation", fields: [destinationLocationId], references: [id], onDelete: SetNull)
  currentDriver        Driver?               @relation("ShipmentCurrentDriver", fields: [currentDriverId], references: [id], onDelete: SetNull)
  currentVehicle       Vehicle?              @relation("ShipmentCurrentVehicle", fields: [currentVehicleId], references: [id], onDelete: SetNull)
  currentTrackingSession TrackingSession?    @relation("ShipmentCurrentTrackingSession", fields: [currentTrackingSessionId], references: [id], onDelete: SetNull)
  items                ShipmentItem[]
  stops                ShipmentStop[]
  assignments          ShipmentAssignment[]
  statusEvents         ShipmentStatusEvent[]
  trackingSessions     TrackingSession[]     @relation("ShipmentTrackingSessions")
  trackingPoints       TrackingPoint[]
  documents            Document[]
  proofOfDeliveries    ProofOfDelivery[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@unique([organizationId, shipmentCode])
  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([companyClientId])
  @@index([status])
  @@index([plannedPickupAt])
  @@index([plannedDeliveryAt])
  @@index([currentDriverId])
  @@index([currentTrackingSessionId])
  @@index([invoiceNumber])
  @@map("shipments")
}

model ShipmentItem {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  shipmentId      String        @map("shipment_id") @db.Uuid
  description     String
  quantity        Decimal       @db.Decimal(12, 2)
  unit            String
  weight          Decimal?      @db.Decimal(12, 2)
  volume          Decimal?      @db.Decimal(12, 2)
  declaredValue   Decimal?      @map("declared_value") @db.Decimal(14, 2)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment        Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([shipmentId])
  @@map("shipment_items")
}

model ShipmentStop {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  shipmentId        String       @map("shipment_id") @db.Uuid
  stopSequence      Int          @map("stop_sequence")
  stopType          StopType     @map("stop_type")
  locationName      String       @map("location_name")
  addressLine1      String?      @map("address_line_1")
  addressLine2      String?      @map("address_line_2")
  city              String?
  state             String?
  postalCode        String?      @map("postal_code")
  country           String?      @default("India")
  plannedArrivalAt  DateTime?    @map("planned_arrival_at")
  actualArrivalAt   DateTime?    @map("actual_arrival_at")
  plannedDepartureAt DateTime?   @map("planned_departure_at")
  actualDepartureAt DateTime?    @map("actual_departure_at")
  status            StopStatus   @default(PENDING)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment          Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@unique([shipmentId, stopSequence])
  @@index([organizationId])
  @@index([shipmentId])
  @@index([stopType])
  @@map("shipment_stops")
}

model ShipmentAssignment {
  id               String                   @id @default(uuid()) @db.Uuid
  organizationId   String                   @map("organization_id") @db.Uuid
  shipmentId       String                   @map("shipment_id") @db.Uuid
  driverId         String                   @map("driver_id") @db.Uuid
  vehicleId        String?                  @map("vehicle_id") @db.Uuid
  assignmentStatus ShipmentAssignmentStatus @default(ACTIVE) @map("assignment_status")
  assignedAt       DateTime                 @default(now()) @map("assigned_at")
  unassignedAt     DateTime?                @map("unassigned_at")
  notes            String?
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment         Shipment                 @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver           Driver                   @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle          Vehicle?                 @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([shipmentId])
  @@index([driverId])
  @@index([vehicleId])
  @@index([assignmentStatus])
  @@index([assignedAt])
  @@map("shipment_assignments")
}

model ShipmentStatusEvent {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  shipmentId     String          @map("shipment_id") @db.Uuid
  driverId       String?         @map("driver_id") @db.Uuid
  eventType      String          @map("event_type")
  fromStatus     ShipmentStatus? @map("from_status")
  toStatus       ShipmentStatus? @map("to_status")
  eventTime      DateTime        @default(now()) @map("event_time")
  source         EventSource     @default(SYSTEM)
  notes          String?
  metadata       Json?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment       Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver         Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([shipmentId])
  @@index([eventType])
  @@index([eventTime(sort: Desc)])
  @@map("shipment_status_events")
}

model TrackingSession {
  id            String                @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  shipmentId    String                @map("shipment_id") @db.Uuid
  driverId      String                @map("driver_id") @db.Uuid
  status        TrackingSessionStatus @default(ACTIVE)
  startedAt     DateTime              @default(now()) @map("started_at")
  endedAt       DateTime?             @map("ended_at")
  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment      Shipment              @relation("ShipmentTrackingSessions", fields: [shipmentId], references: [id], onDelete: Cascade)
  driver        Driver                @relation(fields: [driverId], references: [id], onDelete: Restrict)
  currentForShipment Shipment?        @relation("ShipmentCurrentTrackingSession")
  trackingPoints TrackingPoint[]
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([shipmentId])
  @@index([driverId])
  @@index([status])
  @@map("tracking_sessions")
}

model TrackingPoint {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  trackingSessionId String       @map("tracking_session_id") @db.Uuid
  shipmentId       String        @map("shipment_id") @db.Uuid
  driverId         String        @map("driver_id") @db.Uuid
  latitude         Decimal       @db.Decimal(10, 7)
  longitude        Decimal       @db.Decimal(10, 7)
  speed            Decimal?      @db.Decimal(10, 2)
  heading          Decimal?      @db.Decimal(10, 2)
  accuracy         Decimal?      @db.Decimal(10, 2)
  recordedAt       DateTime      @default(now()) @map("recorded_at")
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trackingSession  TrackingSession @relation(fields: [trackingSessionId], references: [id], onDelete: Cascade)
  shipment         Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver           Driver        @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([trackingSessionId])
  @@index([shipmentId])
  @@index([driverId])
  @@index([recordedAt(sort: Desc)])
  @@map("tracking_points")
}

model Document {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  shipmentId     String?            @map("shipment_id") @db.Uuid
  entityType     DocumentEntityType @map("entity_type")
  entityId       String             @map("entity_id") @db.Uuid
  documentType   String             @map("document_type")
  fileName       String             @map("file_name")
  storageBucket  String             @map("storage_bucket")
  storageKey     String             @map("storage_key")
  mimeType       String?            @map("mime_type")
  fileSize       Int?               @map("file_size")
  status         DocumentStatus     @default(UPLOADED)
  uploadedBy     String?            @map("uploaded_by") @db.Uuid
  uploadedAt     DateTime           @default(now()) @map("uploaded_at")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment       Shipment?          @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  pickupProofs   ProofOfDelivery[]  @relation("PickupPhotoDocument")
  signatureProofs ProofOfDelivery[] @relation("SignatureDocument")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([shipmentId])
  @@index([entityType, entityId])
  @@index([documentType])
  @@index([uploadedAt(sort: Desc)])
  @@map("documents")
}

model ProofOfDelivery {
  id                 String      @id @default(uuid()) @db.Uuid
  organizationId     String      @map("organization_id") @db.Uuid
  shipmentId         String      @map("shipment_id") @db.Uuid
  proofType          ProofType   @map("proof_type")
  photoDocumentId    String?     @map("photo_document_id") @db.Uuid
  signatureDocumentId String?    @map("signature_document_id") @db.Uuid
  receiverName       String?     @map("receiver_name")
  receiverPhone      String?     @map("receiver_phone")
  remarks            String?
  capturedBy         String?     @map("captured_by") @db.Uuid
  capturedAt         DateTime    @default(now()) @map("captured_at")
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment           Shipment    @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  photoDocument      Document?   @relation("PickupPhotoDocument", fields: [photoDocumentId], references: [id], onDelete: SetNull)
  signatureDocument  Document?   @relation("SignatureDocument", fields: [signatureDocumentId], references: [id], onDelete: SetNull)
  createdAt          DateTime    @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([shipmentId])
  @@index([proofType])
  @@index([capturedAt(sort: Desc)])
  @@map("proof_of_delivery")
}

model IndependentDriverRegistration {
  id                        String                                @id @default(uuid()) @db.Uuid
  organizationId            String?                               @map("organization_id") @db.Uuid
  fullName                  String                                @map("full_name")
  phone                     String
  email                     String?
  dateOfBirth               DateTime?                             @map("date_of_birth")
  gender                    Gender?
  addressLine1              String                                @map("address_line_1")
  addressLine2              String?                               @map("address_line_2")
  city                      String
  state                     String
  postalCode                String                                @map("postal_code")
  country                   String
  homeBaseLocation          String?                               @map("home_base_location")
  licenseNumber             String                                @map("license_number")
  licenseExpiry             DateTime                              @map("license_expiry")
  licenseType               DriverLicenseType?                    @map("license_type")
  licenseIssueDate          DateTime?                             @map("license_issue_date")
  licenseIssuingState       String?                               @map("license_issuing_state")
  aadhaarNumber             String?                               @map("aadhaar_number")
  panNumber                 String?                               @map("pan_number")
  vehicleNumber             String                                @map("vehicle_number")
  vehicleType               String                                @map("vehicle_type")
  vehicleModel              String?                               @map("vehicle_model")
  vehicleCapacity           Decimal?                              @map("vehicle_capacity") @db.Decimal(12, 2)
  vehicleOwnerName          String?                               @map("vehicle_owner_name")
  vehicleRegistrationState  String?                               @map("vehicle_registration_state")
  fuelType                  FuelType?                             @map("fuel_type")
  uploadedDocuments         Json                                  @map("uploaded_documents")
  status                    IndependentDriverRegistrationStatus   @default(PENDING_APPROVAL)
  approvedAt                DateTime?                             @map("approved_at")
  approvedByUserId          String?                               @map("approved_by_user_id") @db.Uuid
  rejectedAt                DateTime?                             @map("rejected_at")
  rejectedReason            String?                               @map("rejected_reason")
  organization              Organization?                         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  approvedByUser            User?                                 @relation("IndependentDriverApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                              @default(now()) @map("created_at")
  updatedAt                 DateTime                              @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([phone])
  @@index([vehicleNumber])
  @@index([status])
  @@map("independent_driver_registrations")
}
